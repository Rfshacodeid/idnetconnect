<IfModule mod_rewrite.c>
    RewriteEngine On

    # Blokir akses langsung ke file JS kecuali:
    # 1. Request berasal dari domain Anda sendiri (referer)
    # 2. User-Agent adalah Googlebot (crawler Google) atau Chrome
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteCond %{REQUEST_URI} \.js$ [NC]
    RewriteCond %{HTTP_REFERER} !^https?://(www\.)?idnetconnect\.biz\.id [NC]
    RewriteCond %{HTTP_USER_AGENT} !(googlebot|chrome|chromium) [NC]
    RewriteRule .* - [F,L]
</IfModule>

<FilesMatch "\.(js)$">
    # Header keamanan tambahan
    <IfModule mod_headers.c>
        Header set X-Content-Type-Options "nosniff"
        Header set Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval' *.idnetconnect.biz.id"
        Header set X-Frame-Options "DENY"
        Header set Permissions-Policy "interest-cohort=()"
    </IfModule>

    # Hanya izinkan metode GET/HEAD
    <LimitExcept GET HEAD>
        Deny from all
    </LimitExcept>
</FilesMatch>

# Blokir akses ke file sensitif
<Files ~ "\.(env|htaccess|htpasswd|ini|sql|log|sh|php|json)$">
    Require all denied
</Files>
