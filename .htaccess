<FilesMatch "\.(js)$">
    # Aktifkan mod_headers dan mod_rewrite jika diperlukan
    <IfModule mod_headers.c>
        # Blok akses langsung ke file JS via browser
        Header set X-Content-Type-Options "nosniff"
        Header set Content-Security-Policy "default-src 'self'"
        Header set X-Frame-Options "DENY"
    </IfModule>

    # Blok akses langsung ke file JS
    <IfModule mod_rewrite.c>
        RewriteEngine On
        # Izinkan akses hanya dari domain Anda sendiri (ganti example.com)
        RewriteCond %{HTTP_REFERER} !^https?://(www\.)?idnetconnect\.biz.id/.*$ [NC]
        RewriteRule .* - [F]
    </IfModule>

    # Blok metode HTTP selain GET/HEAD
    <LimitExcept GET HEAD>
        Deny from all
    </LimitExcept>
</FilesMatch>

# Blok akses ke semua file penting
<Files ~ "\.(env|log|htaccess|htpasswd|ini|phps|fla|psd|log|sh|php|sql|json|js)$">
    Order allow,deny
    Deny from all
</Files>
